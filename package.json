{
  "name": "siege-launcher",
  "private": true,
  "version": "0.7.1",
  "type": "commonjs",
  "main": "electron/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-store": "^11.0.2",
    "follow-redirects": "^1.15.11",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-vue": "^6.0.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.4",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.siegelauncher.desktop",
    "productName": "Siege Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "shared/icon.png"
    },
    "extraResources": [
      {
        "from": "steam/depotdownloader",
        "to": "steam/depotdownloader"
      }
    ]
  }
}